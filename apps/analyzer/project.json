{
  "name": "analyzer",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/analyzer/app",
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "source .venv/bin/activate && uvicorn app.main:app --reload --port 8000",
        "cwd": "apps/analyzer"
      }
    }
  }
}
